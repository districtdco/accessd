# ══════════════════════════════════════════════════════════════════════════════
# AccessD — production nginx configuration
# Serves built UI static files and proxies API routes to the Go backend.
# Adjust server_name, cert/key paths, and static root before use.
#
# Prerequisites:
#   - UI built with `npm run build`, output copied to /var/www/accessd/
#   - TLS certificate provisioned (certbot, internal CA, etc.)
#   - nginx >= 1.18
# ══════════════════════════════════════════════════════════════════════════════

map $http_x_request_id $accessd_request_id {
    default $http_x_request_id;
    ""      $request_id;
}

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name accessd.example.internal;

    location /.well-known/acme-challenge/ {
        root /var/www/acme;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS main server ─────────────────────────────────────────────────────────
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name accessd.example.internal;

    ssl_certificate     /etc/ssl/accessd/fullchain.pem;
    ssl_certificate_key /etc/ssl/accessd/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options    "nosniff"                              always;
    add_header X-Frame-Options           "DENY"                                 always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin"      always;
    add_header Permissions-Policy        "geolocation=(), camera=(), microphone=()" always;

    # CSP: connect-src includes the operator-local connector at 127.0.0.1:9494
    # across http/https and ws/wss schemes; frame-src allows custom protocol
    # handoff to the native connector app.
    add_header Content-Security-Policy
        "default-src 'self';
         script-src 'self';
         style-src 'self' 'unsafe-inline';
         img-src 'self' data:;
         font-src 'self' data:;
         connect-src 'self' https://127.0.0.1:9494 https://localhost:9494 http://127.0.0.1:9494 http://localhost:9494 wss://127.0.0.1:9494 wss://localhost:9494 ws://127.0.0.1:9494 ws://localhost:9494;
         frame-src 'self' accessd-connector:;
         worker-src 'self' blob:;
         frame-ancestors 'none';
         object-src 'none';
         base-uri 'self';"
        always;

    client_max_body_size 1m;
    proxy_read_timeout   60s;
    proxy_send_timeout   60s;
    proxy_connect_timeout 10s;

    # ── UI static files (built React SPA) ────────────────────────────────────
    root /var/www/accessd;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;

        location ~* \.(js|css|woff2?|ttf|ico|png|svg|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            add_header X-Content-Type-Options "nosniff" always;
        }
    }

    # ── API backend proxy ─────────────────────────────────────────────────────
    location /api/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Request-Id      $accessd_request_id;
        proxy_hide_header X-Powered-By;
        add_header X-Request-Id $accessd_request_id always;
    }

    # ── Connector release binaries (nginx-hosted distribution) ──────────────
    # Publish connector release artifacts under:
    #   /var/www/accessd-downloads/connectors/v<version>/
    # and expose them at:
    #   https://accessd.example.internal/downloads/connectors/v<version>/...
    location /downloads/ {
        alias /var/www/accessd-downloads/;
        autoindex off;
        add_header Cache-Control "public, max-age=300";
        try_files $uri =404;
    }

    # NOTE: Do NOT add a /connector/ proxy location here.
    # The connector runs on the OPERATOR'S machine (not this server).
    # Exposing it via nginx would allow any internet client to trigger
    # local application launches — a critical security risk.

    location ~ /\. {
        deny all;
    }
}
