# ══════════════════════════════════════════════════════════════════════════════
# AccessD Connector — operator-machine environment
# The connector runs on the OPERATOR'S machine, not on the AccessD server.
# Copy to ~/.config/accessd/connector.env or wherever the operator launches it.
#
# REQUIRED fields marked with [REQUIRED]. Must match values in accessd.env.
# ══════════════════════════════════════════════════════════════════════════════

# Bind address — loopback-only. The connector must never bind to a non-loopback
# interface. CORS and HMAC verification are controls if it does, but loopback is preferred.
ACCESSD_CONNECTOR_ADDR=127.0.0.1:9494

# Allowed CORS origin. Set to the AccessD UI origin (the browser-facing domain).
ACCESSD_CONNECTOR_ALLOWED_ORIGIN=https://accessd.example.internal            # [REQUIRED — change]

# Online token verification endpoint (recommended; avoids operator-side shared secret distribution).
# If unset, connector derives: https://<ACCESSD_CONNECTOR_ALLOWED_ORIGIN host>/api/connector/token/verify
# ACCESSD_CONNECTOR_BACKEND_VERIFY_URL=https://accessd.example.internal/api/connector/token/verify

# NEVER enable these unless you have a deliberate architecture reason.
ACCESSD_CONNECTOR_ALLOW_ANY_ORIGIN=false
ACCESSD_CONNECTOR_ALLOW_REMOTE=false
# Optional bootstrap env URL for operator installers.
# If unset, installers try:
# https://<ACCESSD_CONNECTOR_ALLOWED_ORIGIN host>/downloads/bootstrap/accessd-connector.env
# ACCESSD_CONNECTOR_BOOTSTRAP_ENV_URL=https://accessd.example.internal/downloads/bootstrap/accessd-connector.env
ACCESSD_CONNECTOR_AUTO_TRUST_SERVER_CERT=true
# Optional explicit URL for installer trust bootstrap.
# Default if unset: https://<ACCESSD_CONNECTOR_ALLOWED_ORIGIN host>/downloads/certs/accessd-server.crt
# ACCESSD_CONNECTOR_TRUST_CERT_URL=https://accessd.example.internal/downloads/certs/accessd-server.crt

# Optional legacy local-HMAC mode. Prefer backend verify endpoint instead.
# If set, must match ACCESSD_CONNECTOR_SECRET in accessd.env.
# ACCESSD_CONNECTOR_SECRET=CHANGE_ME_BASE64_32_BYTE_CONNECTOR_SECRET

# Emergency-only development override. Keep false in real environments.
ACCESSD_CONNECTOR_ALLOW_INSECURE_NO_TOKEN=false

# Temp file cleanup TTL for DBeaver connection files.
ACCESSD_CONNECTOR_DBEAVER_TEMP_TTL=15m

# Shell bridge proxy host-key behavior on operator machines:
# - strict: fail on unknown or changed proxy key
# - accept-new: auto-add unknown proxy key, fail on changed key
# - accept-replace: auto-add unknown key and auto-replace changed key
ACCESSD_CONNECTOR_PROXY_HOSTKEY_MODE=accept-replace
ACCESSD_CONNECTOR_PROXY_KNOWN_HOSTS_PATH=~/.accessd-connector/proxy_known_hosts

# Redis TLS launch fallback:
# when true and redis_tls=true, connector adds --insecure automatically for redis-cli.
ACCESSD_CONNECTOR_REDIS_TLS_AUTO_INSECURE=false

# Optional: override binary paths if not discoverable via PATH.
# ACCESSD_CONNECTOR_PUTTY_PATH=/usr/bin/putty
# ACCESSD_CONNECTOR_WINSCP_PATH=/usr/bin/winscp
# ACCESSD_CONNECTOR_FILEZILLA_PATH=/usr/bin/filezilla
# ACCESSD_CONNECTOR_DBEAVER_PATH=/opt/dbeaver/dbeaver
# ACCESSD_CONNECTOR_REDIS_CLI_PATH=/usr/bin/redis-cli
