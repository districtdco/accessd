# PAM Connector environment (optional system service)
# Deploy only when connector is intended to run on the same trusted Linux VM.

PAM_CONNECTOR_ADDR=127.0.0.1:9494
PAM_CONNECTOR_ALLOWED_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
PAM_CONNECTOR_ALLOW_ANY_ORIGIN=false
PAM_CONNECTOR_ALLOW_REMOTE=false
PAM_CONNECTOR_SECRET=replace-with-shared-hmac-secret

# Optional binary overrides
PAM_CONNECTOR_PUTTY_PATH=putty
PAM_CONNECTOR_WINSCP_PATH=winscp
PAM_CONNECTOR_FILEZILLA_PATH=filezilla
PAM_CONNECTOR_DBEAVER_TEMP_TTL=15m
