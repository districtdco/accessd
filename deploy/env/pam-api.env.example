# PAM API environment (Linux VM systemd deployment)

# Core
PAM_ENV=production
PAM_APP_NAME=pam-api
PAM_HTTP_ADDR=127.0.0.1:8080
# Optional: explicit API CORS allowlist for browser origins.
# Keep this aligned with your frontend origin(s).
PAM_CORS_ALLOWED_ORIGINS=https://pam.example.com
# Optional: load defaults from an env file. Explicit environment variables still win.
# PAM_CONFIG_FILE=/etc/pam/pam-api.env
PAM_DB_URL=postgres://pam:change-me@127.0.0.1:5432/pam?sslmode=require

# Build metadata (optionally injected by release tooling)
PAM_VERSION=0.1.0
PAM_COMMIT=replace-with-git-sha
PAM_BUILT_AT=2026-04-07T00:00:00Z

# Auth/session hardening
PAM_AUTH_COOKIE_NAME=pam_session
PAM_AUTH_SESSION_TTL=12h
PAM_AUTH_COOKIE_SECURE=true
PAM_AUTH_COOKIE_SAMESITE=strict
PAM_AUTH_PROVIDER_MODE=ldap

# LDAP (Samba AD example)
PAM_LDAP_HOST=dc1.corp.example.com
PAM_LDAP_PORT=636
PAM_LDAP_USE_TLS=true
PAM_LDAP_STARTTLS=false
PAM_LDAP_INSECURE_SKIP_VERIFY=false
PAM_LDAP_BASE_DN=DC=corp,DC=example,DC=com
PAM_LDAP_BIND_DN=CN=pam-reader,OU=Service Accounts,DC=corp,DC=example,DC=com
PAM_LDAP_BIND_PASSWORD=replace-me
PAM_LDAP_USER_FILTER=(&(objectCategory=person)(objectClass=user)({{username_attr}}={{username}}))
PAM_LDAP_USERNAME_ATTR=sAMAccountName
PAM_LDAP_DISPLAY_NAME_ATTR=displayName
PAM_LDAP_EMAIL_ATTR=mail
PAM_LDAP_GROUP_BASE_DN=OU=Groups,DC=corp,DC=example,DC=com
PAM_LDAP_GROUP_FILTER=(&(objectClass=group)(member={{user_dn}}))
PAM_LDAP_GROUP_NAME_ATTR=cn
PAM_LDAP_GROUP_ROLE_MAPPING=PAM Operators=operator,CN=PAM Admins,OU=Groups,DC=corp,DC=example,DC=com=admin|auditor

# Security-sensitive secrets
# Use a base64-encoded 32-byte key in production.
PAM_VAULT_KEY=replace-with-base64-32-byte-key
PAM_VAULT_KEY_ID=v1
PAM_LAUNCH_TOKEN_SECRET=replace-with-strong-random-secret

# SSH proxy
PAM_SSH_PROXY_ADDR=127.0.0.1:2222
PAM_SSH_PROXY_PUBLIC_HOST=pam.example.internal
PAM_SSH_PROXY_PUBLIC_PORT=2222
PAM_SSH_PROXY_USERNAME=pam
PAM_SSH_PROXY_HOST_KEY_PATH=/var/lib/pam/ssh/pam_proxy_host_key
PAM_SSH_PROXY_UPSTREAM_HOSTKEY_MODE=known-hosts
PAM_SSH_PROXY_UPSTREAM_KNOWN_HOSTS_PATH=/var/lib/pam/ssh/upstream_known_hosts
PAM_SSH_PROXY_IDLE_TIMEOUT=5m
PAM_SSH_PROXY_MAX_SESSION_DURATION=8h

# PostgreSQL proxy (session-scoped listeners for DBeaver path)
PAM_PG_PROXY_BIND_HOST=127.0.0.1
PAM_PG_PROXY_PUBLIC_HOST=pam.example.internal
PAM_PG_PROXY_CONNECT_TIMEOUT=10s
PAM_PG_PROXY_QUERY_LOG_QUEUE=1024
PAM_PG_PROXY_QUERY_MAX_BYTES=16384
PAM_PG_PROXY_IDLE_TIMEOUT=5m
PAM_PG_PROXY_MAX_SESSION_DURATION=8h

# MySQL proxy (session-scoped listeners for DBeaver path)
PAM_MYSQL_PROXY_BIND_HOST=127.0.0.1
PAM_MYSQL_PROXY_PUBLIC_HOST=pam.example.internal
PAM_MYSQL_PROXY_CONNECT_TIMEOUT=10s
PAM_MYSQL_PROXY_QUERY_LOG_QUEUE=1024
PAM_MYSQL_PROXY_QUERY_MAX_BYTES=16384
PAM_MYSQL_PROXY_IDLE_TIMEOUT=5m
PAM_MYSQL_PROXY_MAX_SESSION_DURATION=8h

# MSSQL proxy (session-scoped listeners for DBeaver path)
PAM_MSSQL_PROXY_BIND_HOST=127.0.0.1
PAM_MSSQL_PROXY_PUBLIC_HOST=pam.example.internal
PAM_MSSQL_PROXY_CONNECT_TIMEOUT=10s
PAM_MSSQL_PROXY_QUERY_LOG_QUEUE=1024
PAM_MSSQL_PROXY_QUERY_MAX_BYTES=16384
PAM_MSSQL_PROXY_IDLE_TIMEOUT=5m
PAM_MSSQL_PROXY_MAX_SESSION_DURATION=8h

# Redis proxy (session-scoped listeners for redis-cli path)
PAM_REDIS_PROXY_BIND_HOST=127.0.0.1
PAM_REDIS_PROXY_PUBLIC_HOST=pam.example.internal
PAM_REDIS_PROXY_CONNECT_TIMEOUT=10s
PAM_REDIS_PROXY_COMMAND_LOG_QUEUE=1024
PAM_REDIS_PROXY_ARG_MAX_LEN=128
PAM_REDIS_PROXY_IDLE_TIMEOUT=5m
PAM_REDIS_PROXY_MAX_SESSION_DURATION=8h

# Keep false for production.
PAM_ALLOW_UNSAFE_MODE=false
