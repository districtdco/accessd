# ══════════════════════════════════════════════════════════════════════════════
# AccessD — production runtime environment
# Deploy to: /etc/accessd/accessd.env  (chmod 0640, chown root:accessd)
#
# REQUIRED fields marked with [REQUIRED]. Defaults marked [default: ...].
# All lines with placeholder values MUST be changed before first start.
#
# Use ACCESSD_* variables only.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────────────────
ACCESSD_ENV=production
ACCESSD_APP_NAME=accessd

# HTTP listener — keep this on loopback. TLS is terminated at nginx.       [REQUIRED]
ACCESSD_HTTP_ADDR=127.0.0.1:8080

# Allowed browser origins for CORS. Must match your nginx server_name.     [REQUIRED]
ACCESSD_CORS_ALLOWED_ORIGINS=https://accessd.example.internal

# Path to SQL migration files. Absolute path avoids working-dir ambiguity. [REQUIRED]
ACCESSD_MIGRATIONS_DIR=/opt/accessd/migrations

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string includes password — protect this file with 0640.       [REQUIRED]
# Use sslmode=verify-full when PostgreSQL has a verifiable TLS cert.
ACCESSD_DB_URL=postgres://accessd:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/accessd?sslmode=require
ACCESSD_DB_MAX_CONNS=10
ACCESSD_DB_MIN_CONNS=2
ACCESSD_DB_MAX_CONN_LIFETIME=1h
ACCESSD_DB_MAX_CONN_IDLE_TIME=15m

# ── Secrets — must all be replaced before deployment ─────────────────────────
#
# ACCESSD_VAULT_KEY: AES-256 master key for credential encryption.
#   Generate: openssl rand -base64 32
#   Must be base64-encoded 32 bytes in production. Rotation requires
#   re-encrypting all stored credentials (v1 limitation — manual process).
ACCESSD_VAULT_KEY=CHANGE_ME_BASE64_32_BYTE_KEY                               # [REQUIRED]
ACCESSD_VAULT_KEY_ID=v1

# ACCESSD_LAUNCH_TOKEN_SECRET: HMAC key for short-lived session launch tokens.
#   Generate: openssl rand -base64 32
#   Rotating this invalidates any in-flight launch tokens (sessions must
#   be re-launched from the UI).
ACCESSD_LAUNCH_TOKEN_SECRET=CHANGE_ME_BASE64_32_BYTE_SECRET                  # [REQUIRED]

# ACCESSD_CONNECTOR_SECRET: Shared HMAC key between API and connector.
#   Generate: openssl rand -base64 32
#   Must match ACCESSD_CONNECTOR_SECRET in accessd-connector.env.
#   When set, connector verifies every launch payload signature.
ACCESSD_CONNECTOR_SECRET=CHANGE_ME_BASE64_32_BYTE_CONNECTOR_SECRET           # [REQUIRED]

# ── Bootstrap admin credentials ───────────────────────────────────────────────
# Used on first start to create the initial admin account.
# CHANGE THESE before deployment.
ACCESSD_DEV_ADMIN_USERNAME=admin                                              # [REQUIRED — change]
ACCESSD_DEV_ADMIN_PASSWORD=CHANGE_ME_STRONG_BOOTSTRAP_PASSWORD               # [REQUIRED — change]
ACCESSD_DEV_ADMIN_EMAIL=accessd-admin@example.internal
ACCESSD_DEV_ADMIN_NAME=AccessD Administrator

# ── Auth / session hardening ──────────────────────────────────────────────────
ACCESSD_AUTH_COOKIE_NAME=accessd_session
ACCESSD_AUTH_SESSION_TTL=12h
ACCESSD_AUTH_COOKIE_SECURE=true
ACCESSD_AUTH_COOKIE_SAMESITE=strict

# LDAP auth mode and connection settings are managed in Admin UI (Directory & LDAP)
# and stored in DB. Keep env free from LDAP runtime config to avoid drift.

# ── SSH proxy ─────────────────────────────────────────────────────────────────
ACCESSD_SSH_PROXY_ADDR=0.0.0.0:2222
ACCESSD_SSH_PROXY_PUBLIC_HOST=accessd.example.internal                        # [REQUIRED — operator-visible hostname]
ACCESSD_SSH_PROXY_PUBLIC_PORT=2222
ACCESSD_SSH_PROXY_USERNAME=accessd
ACCESSD_SSH_PROXY_HOST_KEY_PATH=/var/lib/accessd/ssh/accessd_proxy_host_key
ACCESSD_SSH_PROXY_UPSTREAM_HOSTKEY_MODE=accept-new
ACCESSD_SSH_PROXY_UPSTREAM_KNOWN_HOSTS_PATH=/var/lib/accessd/ssh/upstream_known_hosts
ACCESSD_SSH_PROXY_UPSTREAM_HOSTKEY_AUTO_REPAIR=true
ACCESSD_SSH_PROXY_IDLE_TIMEOUT=5m
ACCESSD_SSH_PROXY_MAX_SESSION_DURATION=8h

# ── Database proxies ──────────────────────────────────────────────────────────
# Bind to all interfaces so operator-side connector/clients can reach session
# proxy ports through ACCESSD_*_PROXY_PUBLIC_HOST.
ACCESSD_PG_PROXY_BIND_HOST=0.0.0.0
ACCESSD_PG_PROXY_PUBLIC_HOST=accessd.example.internal
ACCESSD_PG_PROXY_CONNECT_TIMEOUT=10s
ACCESSD_PG_PROXY_QUERY_LOG_QUEUE=1024
ACCESSD_PG_PROXY_QUERY_MAX_BYTES=16384
ACCESSD_PG_PROXY_IDLE_TIMEOUT=5m
ACCESSD_PG_PROXY_MAX_SESSION_DURATION=8h

ACCESSD_MYSQL_PROXY_BIND_HOST=0.0.0.0
ACCESSD_MYSQL_PROXY_PUBLIC_HOST=accessd.example.internal
ACCESSD_MYSQL_PROXY_CONNECT_TIMEOUT=10s
ACCESSD_MYSQL_PROXY_QUERY_LOG_QUEUE=1024
ACCESSD_MYSQL_PROXY_QUERY_MAX_BYTES=16384
ACCESSD_MYSQL_PROXY_IDLE_TIMEOUT=5m
ACCESSD_MYSQL_PROXY_MAX_SESSION_DURATION=8h

ACCESSD_MSSQL_PROXY_BIND_HOST=0.0.0.0
ACCESSD_MSSQL_PROXY_PUBLIC_HOST=accessd.example.internal
ACCESSD_MSSQL_PROXY_CONNECT_TIMEOUT=10s
ACCESSD_MSSQL_PROXY_QUERY_LOG_QUEUE=1024
ACCESSD_MSSQL_PROXY_QUERY_MAX_BYTES=16384
ACCESSD_MSSQL_PROXY_IDLE_TIMEOUT=5m
ACCESSD_MSSQL_PROXY_MAX_SESSION_DURATION=8h

ACCESSD_MONGO_PROXY_BIND_HOST=0.0.0.0
ACCESSD_MONGO_PROXY_PUBLIC_HOST=accessd.example.internal
ACCESSD_MONGO_PROXY_CONNECT_TIMEOUT=10s
ACCESSD_MONGO_PROXY_IDLE_TIMEOUT=5m
ACCESSD_MONGO_PROXY_MAX_SESSION_DURATION=8h

ACCESSD_REDIS_PROXY_BIND_HOST=0.0.0.0
ACCESSD_REDIS_PROXY_PUBLIC_HOST=accessd.example.internal
ACCESSD_REDIS_PROXY_CONNECT_TIMEOUT=10s
ACCESSD_REDIS_PROXY_COMMAND_LOG_QUEUE=1024
ACCESSD_REDIS_PROXY_ARG_MAX_LEN=128
ACCESSD_REDIS_PROXY_IDLE_TIMEOUT=5m
ACCESSD_REDIS_PROXY_MAX_SESSION_DURATION=8h

# ── Launch tuning ─────────────────────────────────────────────────────────────
ACCESSD_LAUNCH_TOKEN_TTL=2m
ACCESSD_LAUNCH_MATERIALIZE_TIMEOUT=45s
ACCESSD_LAUNCH_SWEEP_INTERVAL=15s

# ── Build metadata ────────────────────────────────────────────────────────────
ACCESSD_VERSION=0.1.0
ACCESSD_COMMIT=replace-with-git-sha
ACCESSD_BUILT_AT=2026-01-01T00:00:00Z

# ── Connector distribution metadata ───────────────────────────────────────────
# Used by UI and APIs to surface correct connector downloads per OS/arch.
# Expected nginx-hosted path, for example:
#   https://accessd.example.internal/downloads/connectors
# Release files are served as:
#   <base>/v<version>/accessd-connector-<version>-<os>-<arch>.<ext>
ACCESSD_CONNECTOR_RELEASES_BASE_URL=https://accessd.example.internal/downloads/connectors
# On-disk connector artifact root used by API to advertise only files that exist.
ACCESSD_CONNECTOR_RELEASES_FS_ROOT=/var/www/accessd-downloads/connectors
ACCESSD_CONNECTOR_LATEST_VERSION=0.1.0
ACCESSD_CONNECTOR_MIN_VERSION=0.1.0
ACCESSD_CONNECTOR_RELEASE_CHANNEL=stable

# ── Safety: must be false in production ──────────────────────────────────────
ACCESSD_ALLOW_UNSAFE_MODE=false
